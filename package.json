{
  "name": "poe-zh-trade-tools-pro",
  "displayName": "Poe Zh Trade Tools Pro",
  "version": "3.28.1",
  "packageManager": "pnpm@11.3.0",
  "license": "MIT",
  "description": "Traditional/Simplified Chinese localization plus bookmarks, history and result tools for the Path of Exile trade site.",
  "author": "MooHui Dev",
  "contributors": [
    "KroxiLabs (original Poe Trade Plus)",
    "louisgv",
    "joacoesteban"
  ],
  "scripts": {
    "dev": "wxt",
    "whats-new": "node scripts/generate-whats-new.cjs",
    "test:bookmark-exports": "node --no-warnings --experimental-strip-types --test tests/bookmark-export-compatibility.test.mjs",
    "typecheck": "tsc --noEmit",
    "build:chrome": "node scripts/wxt-runner.cjs build",
    "build": "pnpm run build:chrome",
    "version": "node scripts/bump-version.cjs",
    "zip:chrome": "node scripts/wxt-runner.cjs zip",
    "package:chrome": "pnpm run zip:chrome",
    "package": "pnpm run package:chrome",
    "release:check": "node scripts/release.cjs check",
    "release:prepare": "node scripts/release.cjs prepare",
    "release:publish": "node scripts/release.cjs publish",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "lucide-static": "^1.24.0",
    "opencc-js": "^1.4.1",
    "svelte": "^5.56.5"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/chrome": "0.2.2",
    "@types/node": "26.1.1",
    "@wxt-dev/module-svelte": "^2.0.5",
    "prettier": "3.9.5",
    "typescript": "^7.0.2",
    "wxt": "^0.20.27"
  },
  "overrides": {
    "content-security-policy-parser": "0.6.0",
    "msgpackr": "^1.11.9",
    "@babel/core": "^7.29.7",
    "brace-expansion": "^5.0.6",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15",
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1",
    "vite": "^8.0.16",
    "svelte": "^5.56.3"
  }
}
